ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auth — generate JWT_SECRET with: python -c "import secrets; print(secrets.token_hex(32))"
# DEV_BYPASS_AUTH=true skips JWT on localhost and accepts dev-free/dev-plus/dev-pro tokens.
# NEVER enable this in production.
DEV_BYPASS_AUTH=true
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Job search (JSearch via RapidAPI — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tailormycv
ALLOWED_ORIGINS=http://localhost:4000
SUPPORT_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password

# Model names — change these to swap models without touching any code
GENERATOR_MODEL=claude-sonnet-4-20250514
ANTHROPIC_EVALUATOR_MODEL=claude-sonnet-4-20250514
OPENAI_EVALUATOR_MODEL=gpt-4o-mini
GOOGLE_EVALUATOR_MODEL=gemini-1.5-pro

# File storage
# Switch STORAGE_BACKEND to change where uploaded files are persisted.
# No code changes needed — the factory in services/storage/__init__.py reads this.
#
#   local  →  files saved to STORAGE_LOCAL_PATH (dev / single-server)
#   s3     →  files uploaded to AWS S3 (production / multi-instance)
#
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# S3 settings — only needed when STORAGE_BACKEND=s3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PREFIX=uploads/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Leave AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY blank to use the instance
# profile or environment credential chain (recommended on EC2 / ECS / Railway).

# Skill extraction — number of key skills the JobAnalyzerAgent picks from the JD
# Maps to subscription tier (override per-user when billing is wired):
#   Free  = 3  |  Plus = 5  |  Pro = 10
SKILL_EXTRACTION_COUNT=3

# Evaluator feature flags — map to subscription tiers:
#
#   Free  (default) : Anthropic only
#     ANTHROPIC_EVALUATOR_ENABLED=true
#     OPENAI_EVALUATOR_ENABLED=false
#     GOOGLE_EVALUATOR_ENABLED=false
#
#   Pro              : Anthropic + Google
#     ANTHROPIC_EVALUATOR_ENABLED=true
#     OPENAI_EVALUATOR_ENABLED=false
#     GOOGLE_EVALUATOR_ENABLED=true
#
#   Premium          : Anthropic + OpenAI + Google (all three)
#     ANTHROPIC_EVALUATOR_ENABLED=true
#     OPENAI_EVALUATOR_ENABLED=true
#     GOOGLE_EVALUATOR_ENABLED=true
#
# Flip these per-user at runtime once subscription checks are wired in.
ANTHROPIC_EVALUATOR_ENABLED=true
OPENAI_EVALUATOR_ENABLED=false
GOOGLE_EVALUATOR_ENABLED=false

# Pipeline quality controls
# PASS_THRESHOLD: minimum score (0-100) for a resume to be considered passing
PASS_THRESHOLD=50
# MAX_EVAL_CYCLES: maximum generator-evaluator loops per request (caps LLM calls)
MAX_EVAL_CYCLES=3

# Per-session AI cost cap
# MAX_AI_CALLS_PER_SESSION: hard limit on total LLM calls per session (0 = unlimited)
MAX_AI_CALLS_PER_SESSION=10

# Feature flags
# PDF_EXPORT_ENABLED: requires LibreOffice on the server — keep false unless set up
PDF_EXPORT_ENABLED=false
# FEATURED_PROFESSION_SLUG: default profession when no keyword match found
FEATURED_PROFESSION_SLUG=software_engineer

# LangSmith tracing (optional)
# Set LANGSMITH_API_KEY to get full LangGraph traces in LangSmith.
# LangChain/LangGraph auto-instruments — no code changes needed beyond this.
# Get your key at: https://smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=tailormycv
