# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
.next/
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets — never commit files with real credentials ────────────────────────
.env
.env.local
.env.*.local
# Allow example/template files and committed environment defaults (no secrets)
!.env.example
!.env.*.example
!.env.development
!.env.production
!.env.uat

# ── Uploaded user files ───────────────────────────────────────────────────────
backend/uploads/
!backend/uploads/.gitkeep
backend/templates/uploads/*
!backend/templates/uploads/.gitkeep
